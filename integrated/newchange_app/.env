# Database Configuration (XAMPP MySQL)
# Keep DB_HOST as 127.0.0.1 — the database is local to this laptop.
# Flask itself binds to 0.0.0.0 (all interfaces) so phones on the same
# network can reach it, but MySQL always connects via localhost.
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=attendance_dbim
DB_PORT=3306

# Flask server settings
# host=0.0.0.0 is set directly in app.py — no override needed here
FLASK_DEBUG=True

# Security
SECRET_KEY=yoursecretkeyhere

# Gmail SMTP Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
